---
export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonicalURL?: string;
  articleDate?: string;
  schema?: object;
}

const {
  title,
  description = 'Rigorous analysis of emerging concepts in crypto, governance, and decentralized systems.',
  ogImage = '/images/og-default.png',
  ogType = 'website',
  canonicalURL = Astro.url.href,
  articleDate,
  schema,
} = Astro.props;

const siteTitle = title === 'Critical Reviews'
  ? 'Critical Reviews'
  : `${title} — Critical Reviews`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />

  <title>{siteTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:type" content={ogType} />
  <meta property="og:title" content={siteTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(ogImage, Astro.site).href} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:site_name" content="Critical Reviews" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={siteTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(ogImage, Astro.site).href} />

  {articleDate && <meta property="article:published_time" content={articleDate} />}

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

  <!-- Global CSS -->
  <link rel="stylesheet" href="/styles/global.css" />

  <!-- Schema.org structured data -->
  {schema && (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  )}
</head>
<body class="min-h-screen flex flex-col" style="background-color: #04050C; color: #F5F3EE;">

  <!-- ─── Site Header ──────────────────────────────────────────────────── -->
  <header class="sticky top-0 z-50 border-b" style="background-color: rgba(4,5,12,0.95); border-color: #1F2937; backdrop-filter: blur(8px);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-14">
        <!-- Logo / Brand -->
        <a href="/" class="flex items-center gap-3 no-underline group">
          <div class="w-7 h-7 rounded flex items-center justify-center text-xs font-bold" style="background-color: #C9A84C; color: #04050C;">CR</div>
          <span class="font-semibold tracking-wide text-sm" style="font-family: 'Lora', serif; color: #F5F3EE;">Critical Reviews</span>
        </a>

        <!-- Nav -->
        <nav class="hidden sm:flex items-center gap-6 text-sm">
          <a href="/" class="no-underline transition-colors" style="color: #9CA3AF;" onmouseover="this.style.color='#C9A84C'" onmouseout="this.style.color='#9CA3AF'">Reviews</a>
          <a href="/about" class="no-underline transition-colors" style="color: #9CA3AF;" onmouseover="this.style.color='#C9A84C'" onmouseout="this.style.color='#9CA3AF'">About</a>
        </nav>

        <!-- Mobile menu button -->
        <button id="mobile-menu-btn" class="sm:hidden p-2 rounded" style="color: #9CA3AF;" aria-label="Menu">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>

      <!-- Mobile nav -->
      <div id="mobile-menu" class="sm:hidden hidden pb-3 border-t" style="border-color: #1F2937;">
        <nav class="flex flex-col gap-2 pt-3 text-sm">
          <a href="/" class="px-2 py-1 rounded no-underline" style="color: #9CA3AF;">Reviews</a>
          <a href="/about" class="px-2 py-1 rounded no-underline" style="color: #9CA3AF;">About</a>
        </nav>
      </div>
    </div>
  </header>

  <!-- ─── Main Content ─────────────────────────────────────────────────── -->
  <main class="flex-1">
    <slot />
  </main>

  <!-- ─── Footer ───────────────────────────────────────────────────────── -->
  <footer class="border-t mt-16" style="border-color: #1F2937; background-color: #0A0D1E;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
        <div>
          <div class="flex items-center gap-2 mb-2">
            <div class="w-5 h-5 rounded text-xs font-bold flex items-center justify-center" style="background-color: #C9A84C; color: #04050C;">CR</div>
            <span class="font-semibold text-sm" style="font-family: 'Lora', serif;">Critical Reviews</span>
          </div>
          <p class="text-xs" style="color: #6B7280;">Rigorous analysis of emerging concepts in crypto, governance, and decentralized systems.</p>
          <p class="text-xs mt-1" style="color: #4B5563;">A <strong style="color: #6B7280;">Sebastian Productions</strong> brick &mdash; from the team behind <a href="https://contrarianalpha.io" class="no-underline" style="color: #6B7280;" onmouseover="this.style.color='#C9A84C'" onmouseout="this.style.color='#6B7280'">Contrarian Alpha</a></p>
        </div>
        <div class="text-xs" style="color: #4B5563;">
          &copy; {new Date().getFullYear()} Sebastian Productions / Bastomatic. All rights reserved.
        </div>
      </div>
    </div>
  </footer>

  <!-- Mobile menu toggle script -->
  <script>
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    btn?.addEventListener('click', () => {
      menu?.classList.toggle('hidden');
    });
  </script>

</body>
</html>
